# Invoice Ninja API Configuration
INVOICE_NINJA_URL=https://your-invoice-ninja-instance.com
INVOICE_NINJA_TOKEN=your-api-token-here
INVOICE_NINJA_PER_PAGE=250

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=hoa@example.com
EMAIL_TO=recipients@example.com

# Report Configuration
REPORT_TITLE=HOA Financial Report
REPORT_PERIOD=monthly
CHART_COLOR_SCHEME=brewer.Paired12

# Company information displayed on the cover page and closing page.
# These values are automatically populated from Invoice Ninja during sync.
# Set any of these variables ONLY if you need to OVERRIDE the Invoice Ninja data
# for a specific field (e.g. to use a different logo or a custom address).
# Leave blank to use the values fetched from Invoice Ninja.
# COMPANY_LOGO_URL can be an https:// URL, a local file path (e.g. ./logo.png),
# or a data: URI. If blank, the logo is taken from Invoice Ninja.
COMPANY_NAME=
COMPANY_RNC=
COMPANY_WEBSITE=
COMPANY_EMAIL=
COMPANY_ADDRESS=
COMPANY_LOGO_URL=

# Path to the Markdown file loaded as the "Documentación del Informe" page.
# Defaults to ./report-docs.md if not set. Set to empty to omit the page.
REPORT_DOCS_PATH=./report-docs.md

# Initial bank balance to add to the perpetual cash-flow result (Balance en Banco).
# Set this to the real opening balance of the HOA bank account so the displayed
# "Balance en Banco" figure can be reconciled against the actual bank statement.
# Defaults to 0 if omitted.
INITIAL_BANK_BALANCE=0

# Minimum number of invoices a client must have in CxC for their contact name
# sub-row to appear. Defaults to 3 if not set.
CXC_CONTACT_MIN_INVOICES=3

PORT=3000

# Local SQLite cache — used by the sync and report commands.
# Defaults to ./hoa-cache.db (a persistent file in the project root).
# Set to :memory: for a temporary in-memory database (useful for testing,
# but sync and report commands must run in the same process).
DB_CACHE_PATH=./hoa-cache.db
